# データベース（PostgreSQL）
# Docker Compose 利用時:
DATABASE_URL=postgres://quantumy:quantumy_secret@localhost:5432/quantumy
# 手元の Postgres の例:
# DATABASE_URL=postgres://user:password@localhost:5432/quantumy

# SQLite の場合の例
# DATABASE_URL=sqlite://./data.db

# ログレベル（任意）
RUST_LOG=info,tower_http=debug

# JWT（進捗APIなどの認証用）
# 本番では必ず別の十分ランダムな値にしてください
JWT_SECRET=dev_change_me

# アクセストークン有効期限（秒）。未設定時は 86400（24時間）
# JWT_ACCESS_TTL_SECS=3600

# 論文→ネーム案 AI パイプライン（任意）— 未設定ならルールベースのモック応答
# POST /api/ai/ingest → B1_segment → B2_chunk → B3_summarize → C3_name_generate
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Stripe Checkout（POST /api/checkout/session）
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_SUCCESS_URL=https://uiux-quamtumy.vercel.app/?checkout=success
# STRIPE_CANCEL_URL=https://uiux-quamtumy.vercel.app/?checkout=cancel

# Stripe Webhook（POST /api/webhooks/stripe）— Dashboard の Signing secret（whsec_...）
# STRIPE_WEBHOOK_SECRET=whsec_...

# CORS allowlist（本番ではフロントのURLを指定）
# 例: https://uiux-quamtumy.vercel.app
FRONTEND_ORIGIN=
